class TemperatureConverter:
    @staticmethod
    def celsius_to_fahrenheit(celsius):
        fahrenheit = (celsius * 1.8) + 32
        return fahrenheit
    @staticmethod
    def fahrenheit_to_celsius(fahrenheit):
        celsius = (fahrenheit - 32) * 5/9
        return celsius
c = float(input("Enter the Celsius temperature: "))
f = float(input("Enter the Fahrenheit temperature: "))
print("Temperature in Fahrenheit:", TemperatureConverter.celsius_to_fahrenheit(c))
print("Temperature in Celsius:", TemperatureConverter.fahrenheit_to_celsius(f))

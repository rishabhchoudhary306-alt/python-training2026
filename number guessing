import random
number = random.randint(1, 50)
attempts = 0
while True:
    guess = int(input("Enter your guess number: "))
    attempts += 1
    if guess > number:
        print("Too High value!")
    elif guess < number:
        print("Too Low value!")
    else:
        print("guess value is correct!")
        print("Attempts:", attempts)
        break

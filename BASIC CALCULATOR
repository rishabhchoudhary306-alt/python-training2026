class Calculator:
    def add(self, a, b):
        return a + b
    def sub(self, a, b):
        return a - b
    def multi(self, a, b):
        return a * b
    def div(self, a, b):
        return a / b
c = Calculator()
x = int(input("Enter first number: "))
y = int(input("Enter second number: "))
print("Addition =", c.add(x, y))
print("Subtraction =", c.sub(x, y))
print("Multiplication =", c.multi(x, y))
print("Division =", c.div(x, y))

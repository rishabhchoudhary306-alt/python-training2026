import random
import string
class WeakPasswordError(Exception):
    pass
class PasswordManager:
    def generate_password(self, length):
        characters = string.ascii_letters + string.digits + string.punctuation
        password = ""
        for i in range(length):
            password += random.choice(characters)
        return password
    def validate_password(self, password):
        if len(password) < 8:
            raise WeakPasswordError(" your Password must contain at least 8 characters.")
        upper = False
        lower = False
        digit = False
        special = False
        for ch in password:

            if ch.isupper():
                upper = True

            elif ch.islower():
                lower = True

            elif ch.isdigit():
                digit = True

            elif ch in string.punctuation:
                special = True

        if not upper:
            raise WeakPasswordError("Password must contain at least one uppercase letter.")

        if not lower:
            raise WeakPasswordError("Password must contain at least one lowercase letter.")

        if not digit:
            raise WeakPasswordError("Password must contain at least one digit.")

        if not special:
            raise WeakPasswordError("Password must contain at least one special character.")

        print("Strong Password ✔")
obj = PasswordManager()
while True:

    print("\n1. Generate Password")
    print("2. Validate Password")
    print("3. Exit")
    choice = int(input("Enter your choice: "))
    if choice == 1:
        length = int(input("Enter your password length: "))
        password = obj.generate_password(length)
        print("Generated Password:", password)
    elif choice == 2:
        password = input("Enter password to validate: ")
        try:
            obj.validate_password(password)
        except WeakPasswordError as e:
            print("Weak Password:", e)
    elif choice == 3:
        print("Program Ended")
        break
    else:
        print("Invalid Choice")
